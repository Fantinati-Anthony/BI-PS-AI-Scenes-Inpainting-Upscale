# Security: Prevent PHP/script execution in custom images directory
<FilesMatch "\.(php|php3|php4|php5|php7|phtml|inc|pl|py|cgi|sh|bash|exe|bat)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

# Only allow image files to be served
<FilesMatch "\.(?:jpg|jpeg|png|webp|gif)$">
    <IfModule mod_headers.c>
        Header set X-Content-Type-Options "nosniff"
        Header set Cache-Control "public, max-age=604800"
    </IfModule>
</FilesMatch>

# Disable directory listing
Options -Indexes
